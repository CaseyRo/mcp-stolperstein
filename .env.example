# Stolperstein MCP Server — Environment Variables
# Copy to .env and fill in values

# --- Transport + Auth ---
TRANSPORT=http
HOST=0.0.0.0
PORT=8716
MCP_STOLPERSTEIN_API_KEY=        # Auto-generated if empty (stmcp_ prefix)
MCP_STOLPERSTEIN_PUBLIC_URL=https://mcp-stolperstein.cdit-dev.de

# --- Cloudflare Access OIDC ---
CF_ACCESS_TEAM=cdit-dev
CF_ACCESS_CLIENT_ID=              # From CF Access for SaaS app
CF_ACCESS_CLIENT_SECRET=          # From CF Access for SaaS app

# --- Storage ---
CQ_LOCAL_DB_PATH=/data/stolperstein.db
CQ_LOG_LEVEL=INFO

# --- Embeddings ---
CQ_EMBEDDING_MODEL=all-MiniLM-L6-v2
CQ_EMBEDDING_API_URL=            # Optional: override local model with API

# --- CQ Team Sync (optional) ---
CQ_TEAM_ADDR=                    # e.g., http://localhost:8742
CQ_TEAM_API_KEY=

# --- Siyuan Sync (optional) ---
CQ_SIYUAN_URL=                   # e.g., http://siyuan:6806
CQ_SIYUAN_NOTEBOOK=Stolpersteine
CQ_SIYUAN_TOKEN=
