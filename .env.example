# Stolperstein MCP Server — Environment Variables
# Copy to .env and fill in values.

# --- Transport + auth ---
TRANSPORT=http
HOST=0.0.0.0
PORT=8716
ALLOWED_HOSTS=*                         # Comma-separated Host-header patterns (fnmatch); "*" = any
MCP_STOLPERSTEIN_API_KEY=               # Auto-generated if empty (stmcp_ prefix)
MCP_STOLPERSTEIN_PUBLIC_URL=https://mcp-stolperstein.cdit-dev.de

# --- Cloudflare Access OIDC ---
CF_ACCESS_TEAM=cdit-dev
CF_ACCESS_CLIENT_ID=                    # From CF Access for SaaS app
CF_ACCESS_CLIENT_SECRET=                # From CF Access for SaaS app

# --- Storage ---
CQ_LOCAL_DB_PATH=/data/stolperstein.db

# --- Provenance / signing key ---
# Private Ed25519 signing key for this install's did:key identifier.
# Base64-encoded 32 bytes. If unset, a key is generated on first boot and
# written to /data/stolperstein.key (mode 0o600). Env var takes priority.
MCP_STOLPERSTEIN_SIGNING_KEY=

# --- Embeddings ---
CQ_EMBEDDING_MODEL=all-MiniLM-L6-v2
CQ_EMBEDDING_API_URL=                   # Optional: override local model with API

# --- LLM for reflect ---
CQ_LLM_API_URL=                         # OpenAI-compatible; empty → heuristic fallback
CQ_LLM_API_KEY=
CQ_LLM_MODEL=gpt-4o-mini

# --- Multi-tenant visibility (Phase 1) ---
TRUSTED_ORGS=*                          # Comma-separated DIDs; "*" = trust-all (default)

# --- Emergent signal detection ---
STOLPERSTEIN_EMERGENT_DISABLED=false
EMERGENT_DETECT_EVERY_N=10              # Trigger aggregation every Nth query-miss
EMERGENT_MIN_MISSES=5                   # Cluster must contain at least N misses
EMERGENT_MIN_SESSIONS=2                 # Across at least N distinct hour-buckets

# --- Claude Code hooks (consumed by plugin handlers, not the server) ---
STOLPERSTEIN_HOOKS_DISABLED=            # Comma list: UserPromptSubmit,PostToolUse,Stop
STOLPERSTEIN_HOOK_COOLDOWN_S=30
STOLPERSTEIN_REFLECT_THRESHOLD=20
STOLPERSTEIN_ERROR_PATTERNS=            # JSON array of regex strings; overrides defaults
